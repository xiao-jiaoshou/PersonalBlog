<Window x:Class="PersonalBlog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PersonalBlog"
        xmlns:vm="clr-namespace:PersonalBlog.ViewModels"
        mc:Ignorable="d"
        Title="个人博客" 
        Height="800" 
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDark}">

    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 左侧侧边栏 -->
        <Border Grid.Column="0" 
                Background="{StaticResource BackgroundDarker}"
                BorderBrush="{StaticResource BorderDark}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 博客标题区域 -->
                <Border Grid.Row="0" 
                        Padding="20,30"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <!-- 头像 -->
                        <Border Width="80" 
                                Height="80" 
                                CornerRadius="40"
                                BorderBrush="{StaticResource GoldPrimary}"
                                BorderThickness="2"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,15">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1E1E1E" Offset="0"/>
                                    <GradientStop Color="#2A2A2A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE77B;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="36"
                                       Foreground="{StaticResource GoldPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        
                        <!-- 博客名称 -->
                        <TextBlock Text="墨香阁" 
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GoldPrimary}"
                                   HorizontalAlignment="Center"
                                   FontFamily="Microsoft YaHei"/>
                        
                        <!-- 副标题 -->
                        <TextBlock Text="记录生活，分享感悟" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"
                                   FontFamily="Microsoft YaHei"/>
                    </StackPanel>
                </Border>
                
                <!-- 导航菜单 -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <!-- 个人简介 -->
                    <Button Content="个人简介" 
                            Tag="&#xE77B;"
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="0">
                        
                    </Button>
                    
                    <!-- 文章分享 -->
                    <Button Content="文章分享" 
                            Tag="&#xE8A9;"
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="1">
                    </Button>
                    
                    <!-- 个人笔记 -->
                    <Button Content="个人笔记" 
                            Tag="&#xE70B;"
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="2">

                    </Button>
                    
                    <!-- 友情链接 -->
                    <Button Content="友情链接" 
                            Tag="&#xE8E1;"
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="3">
                        
                    </Button>
                    
                    <!-- 留言板 -->
                    <Button Content="留言板" 
                            Tag="&#xE8BD;"
                            Style="{StaticResource SidebarButton}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="4">
                        
                    </Button>
                </StackPanel>
                
                <!-- 底部信息 -->
                <Border Grid.Row="2" 
                        Padding="20"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="&#xE946;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="14"
                                   Foreground="{StaticResource GoldMuted}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="黑金主题 v1.0" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="&#169; 2024 墨香阁" 
                                   FontSize="10"
                                   Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- 右侧内容区 -->
        <Border Grid.Column="1" Background="{StaticResource BackgroundDark}">
            <ContentControl Content="{Binding CurrentView}"
                            Margin="30"/>
        </Border>
    </Grid>
</Window>
