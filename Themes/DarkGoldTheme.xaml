<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- 黑金主题配色 -->
    <!-- 主背景色：深黑色 -->
    <SolidColorBrush x:Key="BackgroundDark" Color="#0A0A0A"/>
    <SolidColorBrush x:Key="BackgroundDarker" Color="#050505"/>
    <SolidColorBrush x:Key="BackgroundCard" Color="#141414"/>
    <SolidColorBrush x:Key="BackgroundHover" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="BackgroundSelected" Color="#2A2A2A"/>
    
    <!-- 金色系：主色调 -->
    <SolidColorBrush x:Key="GoldPrimary" Color="#D4AF37"/>
    <SolidColorBrush x:Key="GoldLight" Color="#F4D03F"/>
    <SolidColorBrush x:Key="GoldDark" Color="#B8860B"/>
    <SolidColorBrush x:Key="GoldMuted" Color="#8B7355"/>
    
    <!-- 文字颜色 -->
    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#B0B0B0"/>
    <SolidColorBrush x:Key="TextMuted" Color="#707070"/>
    <SolidColorBrush x:Key="TextGold" Color="#D4AF37"/>
    
    <!-- 边框颜色 -->
    <SolidColorBrush x:Key="BorderDark" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="BorderGold" Color="#D4AF37"/>
    
    <!-- 渐变画刷 -->
    <LinearGradientBrush x:Key="GoldGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D4AF37" Offset="0"/>
        <GradientStop Color="#F4D03F" Offset="0.5"/>
        <GradientStop Color="#B8860B" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="DarkGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#141414" Offset="0"/>
        <GradientStop Color="#0A0A0A" Offset="1"/>
    </LinearGradientBrush>

    <!-- 侧边栏按钮样式 -->
    <Style x:Key="SidebarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            BorderThickness="0"
                            Padding="20,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="icon" 
                                       Text="{TemplateBinding Tag}" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="18"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="text" 
                                       Grid.Column="1"
                                       Text="{TemplateBinding Content}" 
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"
                                       Margin="15,0,0,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundHover}"/>
                            <Setter TargetName="text" Property="Foreground" Value="{StaticResource GoldPrimary}"/>
                            <Setter TargetName="icon" Property="Foreground" Value="{StaticResource GoldPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundSelected}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 选中状态的侧边栏按钮样式 -->
    <Style x:Key="SidebarButtonSelected" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
        <Setter Property="Background" Value="{StaticResource BackgroundSelected}"/>
        <Setter Property="Foreground" Value="{StaticResource GoldPrimary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{StaticResource BackgroundSelected}" 
                            BorderThickness="3,0,0,0"
                            BorderBrush="{StaticResource GoldPrimary}"
                            Padding="17,0,20,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="icon" 
                                       Text="{TemplateBinding Tag}" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="18"
                                       Foreground="{StaticResource GoldPrimary}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="text" 
                                       Grid.Column="1"
                                       Text="{TemplateBinding Content}" 
                                       Foreground="{StaticResource GoldPrimary}"
                                       VerticalAlignment="Center"
                                       Margin="15,0,0,0"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 卡片样式 -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundCard}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="0,0,0,15"/>
    </Style>

    <!-- 标题样式 -->
    <Style x:Key="TitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
    </Style>

    <!-- 副标题样式 -->
    <Style x:Key="SubtitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource GoldPrimary}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- 正文样式 -->
    <Style x:Key="BodyStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="24"/>
    </Style>

    <!-- 输入框样式 -->
    <Style x:Key="InputStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BackgroundCard}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei"/>
        <Setter Property="CaretBrush" Value="{StaticResource GoldPrimary}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource GoldMuted}"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource GoldPrimary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 按钮样式 -->
    <Style x:Key="GoldButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GoldPrimary}"/>
        <Setter Property="Foreground" Value="{StaticResource BackgroundDark}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="25,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource GoldLight}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource GoldDark}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 链接按钮样式 -->
    <Style x:Key="LinkButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource GoldPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <TextBlock x:Name="text" 
                               Text="{TemplateBinding Content}" 
                               Foreground="{TemplateBinding Foreground}"
                               TextDecorations="Underline"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="text" Property="Foreground" Value="{StaticResource GoldLight}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 列表项样式 -->
    <Style x:Key="ListItemStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundCard}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- 滚动条样式 -->
    <Style  TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource BorderDark}"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <!--<Grid>
                        <Border Background="{StaticResource BackgroundCard}" CornerRadius="4"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Background="{StaticResource GoldMuted}" CornerRadius="4"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>-->
                    <Border Background="{StaticResource BorderDark}" CornerRadius="5" Width="15">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Background="{StaticResource GoldMuted}" Width="8" Margin="2,0"/>
                            </Track.Thumb>
                        </Track>
                    </Border>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
