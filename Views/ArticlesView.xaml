<UserControl x:Class="PersonalBlog.Views.ArticlesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- 页面标题 -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="文章分享" 
                           Style="{StaticResource TitleStyle}"
                           Margin="0"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Background="{StaticResource BackgroundCard}" 
                            CornerRadius="6"
                            Padding="15,8"
                            BorderBrush="{StaticResource BorderDark}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71C;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="14"
                                       Foreground="{StaticResource GoldPrimary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="共 128 篇" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
            
            <!-- 分类标签 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border Background="{StaticResource GoldPrimary}" 
                        CornerRadius="15"
                        Padding="15,8"
                        Margin="0,0,10,0">
                    <TextBlock Text="全部" 
                               Foreground="{StaticResource BackgroundDark}"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                </Border>
                <Border Background="{StaticResource BackgroundCard}" 
                        CornerRadius="15"
                        Padding="15,8"
                        Margin="0,0,10,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <TextBlock Text="技术" 
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="13"/>
                </Border>
                <Border Background="{StaticResource BackgroundCard}" 
                        CornerRadius="15"
                        Padding="15,8"
                        Margin="0,0,10,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <TextBlock Text="随笔" 
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="13"/>
                </Border>
                <Border Background="{StaticResource BackgroundCard}" 
                        CornerRadius="15"
                        Padding="15,8"
                        Margin="0,0,10,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <TextBlock Text="教程" 
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="13"/>
                </Border>
                <Border Background="{StaticResource BackgroundCard}" 
                        CornerRadius="15"
                        Padding="15,8"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <TextBlock Text="生活" 
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="13"/>
                </Border>
            </StackPanel>
            
            <!-- 文章列表 -->
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border Background="{StaticResource BackgroundHover}" 
                                CornerRadius="4"
                                Padding="8,4">
                            <TextBlock Text="技术" 
                                       Foreground="{StaticResource GoldPrimary}"
                                       FontSize="11"/>
                        </Border>
                        <TextBlock Text="2024-01-15" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="15,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" 
                               Text="深入理解 WPF 数据绑定机制" 
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,12,0,0"
                               FontFamily="Microsoft YaHei"/>
                    
                    <TextBlock Grid.Row="2" 
                               Text="WPF 的数据绑定是其最强大的特性之一，本文将深入探讨数据绑定的原理、使用场景以及最佳实践..."
                               FontSize="14"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border Background="{StaticResource BackgroundHover}" 
                                CornerRadius="4"
                                Padding="8,4">
                            <TextBlock Text="教程" 
                                       Foreground="{StaticResource GoldPrimary}"
                                       FontSize="11"/>
                        </Border>
                        <TextBlock Text="2024-01-10" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="15,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" 
                               Text="ASP.NET Core 6.0 入门到实战" 
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,12,0,0"
                               FontFamily="Microsoft YaHei"/>
                    
                    <TextBlock Grid.Row="2" 
                               Text="从零开始学习 ASP.NET Core 6.0，包括 MVC 模式、依赖注入、中间件、Entity Framework Core 等核心概念..."
                               FontSize="14"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border Background="{StaticResource BackgroundHover}" 
                                CornerRadius="4"
                                Padding="8,4">
                            <TextBlock Text="随笔" 
                                       Foreground="{StaticResource GoldPrimary}"
                                       FontSize="11"/>
                        </Border>
                        <TextBlock Text="2024-01-05" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="15,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" 
                               Text="2023年技术总结与展望" 
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,12,0,0"
                               FontFamily="Microsoft YaHei"/>
                    
                    <TextBlock Grid.Row="2" 
                               Text="回顾过去一年的技术成长，分享学习心得，展望新一年的技术规划..."
                               FontSize="14"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border Background="{StaticResource BackgroundHover}" 
                                CornerRadius="4"
                                Padding="8,4">
                            <TextBlock Text="技术" 
                                       Foreground="{StaticResource GoldPrimary}"
                                       FontSize="11"/>
                        </Border>
                        <TextBlock Text="2023-12-28" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="15,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" 
                               Text="Vue 3 Composition API 最佳实践" 
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,12,0,0"
                               FontFamily="Microsoft YaHei"/>
                    
                    <TextBlock Grid.Row="2" 
                               Text="Composition API 是 Vue 3 的重大改进，本文分享在实际项目中使用 Composition API 的经验和技巧..."
                               FontSize="14"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border Background="{StaticResource BackgroundHover}" 
                                CornerRadius="4"
                                Padding="8,4">
                            <TextBlock Text="生活" 
                                       Foreground="{StaticResource GoldPrimary}"
                                       FontSize="11"/>
                        </Border>
                        <TextBlock Text="2023-12-20" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="15,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" 
                               Text="程序员的周末：代码之外的生活" 
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,12,0,0"
                               FontFamily="Microsoft YaHei"/>
                    
                    <TextBlock Grid.Row="2" 
                               Text="分享我如何在繁忙的工作之余，找到生活的平衡，培养兴趣爱好..."
                               FontSize="14"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </Grid>
            </Border>
            
            <!-- 加载更多 -->
            <Button Content="加载更多" 
                    Style="{StaticResource GoldButton}"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
