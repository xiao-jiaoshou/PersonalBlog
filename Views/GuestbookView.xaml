<UserControl x:Class="PersonalBlog.Views.GuestbookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- 页面标题 -->
            <TextBlock Text="留言板" 
                       Style="{StaticResource TitleStyle}"/>
            
            <!-- 留言介绍 -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="&#xE8BD;" 
                               FontFamily="Segoe UI Symbol"
                               FontSize="36"
                               Foreground="{StaticResource GoldPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="欢迎留言" 
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"
                               FontFamily="Microsoft YaHei"/>
                    <TextBlock Text="有什么想说的？欢迎留言交流，我会尽快回复。" 
                               FontSize="14"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- 留言表单 -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="发表留言" 
                               Style="{StaticResource SubtitleStyle}"/>
                    
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="昵称" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,0,8"/>
                            <TextBox Style="{StaticResource InputStyle}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="邮箱" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,0,8"/>
                        </StackPanel>
                    </Grid>
                    
                    <StackPanel Margin="0,15,0,0">
                        <TextBlock Text="留言内容" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource InputStyle}"
                                 Height="120"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 Padding="12,12"/>
                    </StackPanel>
                    
                    <Button Content="提交留言" 
                            Style="{StaticResource GoldButton}"
                            HorizontalAlignment="Left"
                            Margin="0,20,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- 留言统计 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="共有 24 条留言" 
                           FontSize="14"
                           Foreground="{StaticResource TextSecondary}"/>
            </StackPanel>
            
            <!-- 留言列表 -->
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Width="45" 
                            Height="45" 
                            CornerRadius="22.5"
                            Background="{StaticResource BackgroundHover}"
                            Margin="0,0,15,0">
                        <TextBlock Text="李" 
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GoldPrimary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="李明" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="2024-01-15 14:30" 
                                       FontSize="12"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="15,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="博主的文章写得真好，学到了很多 WPF 的知识，期待更多优质内容！" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                        
                        <!-- 回复 -->
                        <Border Background="{StaticResource BackgroundHover}" 
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,12,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="博主回复" 
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource GoldPrimary}"/>
                                    <TextBlock Text="2024-01-15 16:45" 
                                               FontSize="11"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="谢谢支持！有问题欢迎随时交流。" 
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Width="45" 
                            Height="45" 
                            CornerRadius="22.5"
                            Background="{StaticResource BackgroundHover}"
                            Margin="0,0,15,0">
                        <TextBlock Text="王" 
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GoldPrimary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="王小明" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="2024-01-12 09:15" 
                                       FontSize="12"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="15,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="请问博主有没有计划写一些关于 .NET MAUI 的文章？最近在学习跨平台开发。" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Width="45" 
                            Height="45" 
                            CornerRadius="22.5"
                            Background="{StaticResource BackgroundHover}"
                            Margin="0,0,15,0">
                        <TextBlock Text="张" 
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GoldPrimary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="张伟" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="2024-01-10 18:20" 
                                       FontSize="12"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="15,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="博客的黑金主题很有质感，是自己设计的吗？" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                        
                        <!-- 回复 -->
                        <Border Background="{StaticResource BackgroundHover}" 
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,12,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="博主回复" 
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource GoldPrimary}"/>
                                    <TextBlock Text="2024-01-10 20:00" 
                                               FontSize="11"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="是的，使用 WPF 自定义的样式，喜欢简约的黑金风格。" 
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Width="45" 
                            Height="45" 
                            CornerRadius="22.5"
                            Background="{StaticResource BackgroundHover}"
                            Margin="0,0,15,0">
                        <TextBlock Text="陈" 
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GoldPrimary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="陈静" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="2024-01-08 11:45" 
                                       FontSize="12"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="15,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="文章写得非常详细，对初学者很友好，已收藏！" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Width="45" 
                            Height="45" 
                            CornerRadius="22.5"
                            Background="{StaticResource BackgroundHover}"
                            Margin="0,0,15,0">
                        <TextBlock Text="刘" 
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GoldPrimary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="刘洋" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="2024-01-05 16:30" 
                                       FontSize="12"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="15,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="希望能多分享一些实战项目的经验，谢谢！" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 加载更多 -->
            <Button Content="加载更多" 
                    Style="{StaticResource GoldButton}"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
