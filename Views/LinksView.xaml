<UserControl x:Class="PersonalBlog.Views.LinksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PersonalBlog.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:LinksViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- 单个链接卡片模板 -->
        <DataTemplate x:Key="LinkCardTemplate">
            <Border Background="{StaticResource BackgroundCard}" 
                    CornerRadius="8"
                    Padding="20"
                    BorderBrush="{StaticResource BorderDark}"
                    BorderThickness="1">
                <StackPanel>
                    <!-- 图标 -->
                    <Border Width="50" 
                            Height="50" 
                            CornerRadius="25"
                            Background="{StaticResource BackgroundHover}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,15">
                        <TextBlock Text="{Binding Icon}" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="24"
                                   Foreground="{StaticResource GoldPrimary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- 标题 -->
                    <TextBlock Text="{Binding Title}" 
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               FontFamily="Microsoft YaHei"/>

                    <!-- 描述 -->
                    <TextBlock Text="{Binding Description}" 
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               LineHeight="20"/>

                    <!-- 按钮 -->
                    <Button Content="{Binding ButtonText}" 
                            Style="{StaticResource LinkButton}"
                            HorizontalAlignment="Left"
                            Margin="0,15,0,0"
                            Tag="{Binding Url}"
                            Click="LinkButton_Click"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- 分类区域模板 -->
        <DataTemplate x:Key="CategoryTemplate">
            <StackPanel Margin="0,0,0,20">
                <!-- 分类标题 -->
                <TextBlock Text="{Binding Title}" 
                           Style="{StaticResource SubtitleStyle}"
                           Margin="0,0,0,15"/>

                <!-- 链接卡片网格：关键！UniformGrid 自动按数量分配列 -->
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 用 ContentPresenter 复用上面的模板 -->
                            <ContentPresenter Content="{Binding}" 
                                            ContentTemplate="{StaticResource LinkCardTemplate}"
                                            Margin="0,0,10,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- 页面标题 -->
            <TextBlock Text="友情链接" 
                       Style="{StaticResource TitleStyle}"/>

            <!-- 介绍卡片 -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="&#xE8E1;" 
                               FontFamily="Segoe UI Symbol"
                               FontSize="36"
                               Foreground="{StaticResource GoldPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="友情链接" 
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"
                               FontFamily="Microsoft YaHei"/>
                    <TextBlock Text="这里汇集了我关注的技术博客和优秀开发者的网站，欢迎访问交流。" 
                               FontSize="14"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 动态渲染所有分类 -->
            <ItemsControl ItemsSource="{Binding Categories}"
                          ItemTemplate="{StaticResource CategoryTemplate}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>