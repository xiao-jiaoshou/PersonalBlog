<UserControl x:Class="PersonalBlog.Views.LinksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- 页面标题 -->
            <TextBlock Text="友情链接" 
                       Style="{StaticResource TitleStyle}"/>
            
            <!-- 介绍 -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="&#xE8E1;" 
                               FontFamily="Segoe UI Symbol"
                               FontSize="36"
                               Foreground="{StaticResource GoldPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="友情链接" 
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"
                               FontFamily="Microsoft YaHei"/>
                    <TextBlock Text="这里汇集了我关注的技术博客和优秀开发者的网站，欢迎访问交流。" 
                               FontSize="14"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- 技术博客 -->
            <TextBlock Text="技术博客" 
                       Style="{StaticResource SubtitleStyle}"
                       Margin="0,0,0,15"/>
            
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,10,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <Border Width="50" 
                                Height="50" 
                                CornerRadius="25"
                                Background="{StaticResource BackgroundHover}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,15">
                            <TextBlock Text="&#xE774;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="24"
                                       Foreground="{StaticResource GoldPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="博客园" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Microsoft YaHei"/>
                        <TextBlock Text="开发者的网上家园" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                        <Button Content="访问网站" 
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="5,0,5,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <Border Width="50" 
                                Height="50" 
                                CornerRadius="25"
                                Background="{StaticResource BackgroundHover}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,15">
                            <TextBlock Text="&#xE774;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="24"
                                       Foreground="{StaticResource GoldPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="CSDN" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Microsoft YaHei"/>
                        <TextBlock Text="专业开发者社区" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                        <Button Content="访问网站" 
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="10,0,0,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <Border Width="50" 
                                Height="50" 
                                CornerRadius="25"
                                Background="{StaticResource BackgroundHover}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,15">
                            <TextBlock Text="&#xE774;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="24"
                                       Foreground="{StaticResource GoldPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="掘金" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Microsoft YaHei"/>
                        <TextBlock Text="帮助开发者成长的社区" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                        <Button Content="访问网站" 
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- 个人博客 -->
            <TextBlock Text="个人博客" 
                       Style="{StaticResource SubtitleStyle}"
                       Margin="0,0,0,15"/>
            
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,10,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <Border Width="50" 
                                Height="50" 
                                CornerRadius="25"
                                Background="{StaticResource BackgroundHover}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,15">
                            <TextBlock Text="&#xE77B;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="24"
                                       Foreground="{StaticResource GoldPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="老张的博客" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Microsoft YaHei"/>
                        <TextBlock Text=".NET 技术专家" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                        <Button Content="访问网站" 
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="5,0,5,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <Border Width="50" 
                                Height="50" 
                                CornerRadius="25"
                                Background="{StaticResource BackgroundHover}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,15">
                            <TextBlock Text="&#xE77B;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="24"
                                       Foreground="{StaticResource GoldPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="前端小站" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Microsoft YaHei"/>
                        <TextBlock Text="Vue/React 技术分享" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                        <Button Content="访问网站" 
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="10,0,0,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <Border Width="50" 
                                Height="50" 
                                CornerRadius="25"
                                Background="{StaticResource BackgroundHover}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,15">
                            <TextBlock Text="&#xE77B;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="24"
                                       Foreground="{StaticResource GoldPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="架构师之路" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Microsoft YaHei"/>
                        <TextBlock Text="系统架构设计分享" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                        <Button Content="访问网站" 
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- 开源项目 -->
            <TextBlock Text="开源项目" 
                       Style="{StaticResource SubtitleStyle}"
                       Margin="0,0,0,15"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,10,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <Border Width="50" 
                                Height="50" 
                                CornerRadius="25"
                                Background="{StaticResource BackgroundHover}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,15">
                            <TextBlock Text="&#xE715;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="24"
                                       Foreground="{StaticResource GoldPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Awesome .NET" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Microsoft YaHei"/>
                        <TextBlock Text="精选 .NET 资源列表" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                        <Button Content="访问项目" 
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="5,0,5,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <Border Width="50" 
                                Height="50" 
                                CornerRadius="25"
                                Background="{StaticResource BackgroundHover}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,15">
                            <TextBlock Text="&#xE715;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="24"
                                       Foreground="{StaticResource GoldPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Vue.js" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Microsoft YaHei"/>
                        <TextBlock Text="渐进式 JavaScript 框架" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                        <Button Content="访问项目" 
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="10,0,0,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <Border Width="50" 
                                Height="50" 
                                CornerRadius="25"
                                Background="{StaticResource BackgroundHover}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,15">
                            <TextBlock Text="&#xE715;" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="24"
                                       Foreground="{StaticResource GoldPrimary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Dapr" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Microsoft YaHei"/>
                        <TextBlock Text="分布式应用运行时" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>
                        <Button Content="访问项目" 
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
