<UserControl x:Class="PersonalBlog.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:PersonalBlog.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:NotesViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- 页面标题 -->
            <TextBlock Text="个人笔记" Style="{StaticResource TitleStyle}"/>

            <!-- 笔记分类（从 Summaries 绑定） -->
            <ItemsControl ItemsSource="{Binding Summaries}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 使用 Button 包裹，使卡片可点击，CommandParameter 为分类 Title -->
                        <Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding Title}"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                            <Border Background="{StaticResource BackgroundCard}" 
                            CornerRadius="8"
                            Padding="60,20"
                            Margin="0"
                            BorderBrush="{StaticResource BorderDark}"
                            BorderThickness="1">    
                                <StackPanel>
                                    <TextBlock Text="{Binding IconGlyph}" 
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="28"
                                       Foreground="{StaticResource GoldPrimary}"/>
                                    <TextBlock Text="{Binding Title}" 
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,10,0,0"/>
                                    <TextBlock Text="{Binding Count, StringFormat={}{0} 篇}" 
                                       FontSize="12"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 最近笔记 -->
            <TextBlock Text="最近笔记" Style="{StaticResource SubtitleStyle}" Margin="0,20,0,15"/>

            <ItemsControl ItemsSource="{Binding RecentNotes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ListItemStyle}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding Title}" 
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Microsoft YaHei"/>

                                <TextBlock Grid.Row="1" Text="{Binding Summary}" 
                                           FontSize="13" Foreground="{StaticResource TextSecondary}"
                                           Margin="0,8,0,0" TextWrapping="Wrap" LineHeight="20"/>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="&#xE8A9;" FontFamily="Segoe UI Symbol" FontSize="12"
                                               Foreground="{StaticResource GoldMuted}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{StaticResource TextMuted}"
                                               Margin="5,0,15,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="&#xE823;" FontFamily="Segoe UI Symbol" FontSize="12"
                                               Foreground="{StaticResource GoldMuted}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" FontSize="11"
                                               Foreground="{StaticResource TextMuted}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Border Grid.Column="1" Grid.RowSpan="3" Background="{StaticResource BackgroundHover}"
                                        CornerRadius="4" Padding="8,4" VerticalAlignment="Top" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Tag}" Foreground="{StaticResource GoldPrimary}" FontSize="11"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>