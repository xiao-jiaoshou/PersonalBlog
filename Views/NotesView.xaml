<UserControl x:Class="PersonalBlog.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- 页面标题 -->
            <TextBlock Text="个人笔记" 
                       Style="{StaticResource TitleStyle}"/>
            
            <!-- 笔记分类 -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,10,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="&#xE8A9;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="28"
                                   Foreground="{StaticResource GoldPrimary}"/>
                        <TextBlock Text="学习笔记" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="45 篇" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="5,0,5,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="&#xE70B;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="28"
                                   Foreground="{StaticResource GoldPrimary}"/>
                        <TextBlock Text="代码片段" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="128 条" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="5,0,5,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="&#xE8C8;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="28"
                                   Foreground="{StaticResource GoldPrimary}"/>
                        <TextBlock Text="待办事项" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="12 项" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="3" 
                        Background="{StaticResource BackgroundCard}" 
                        CornerRadius="8"
                        Padding="20"
                        Margin="10,0,0,0"
                        BorderBrush="{StaticResource BorderDark}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="&#xE946;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="28"
                                   Foreground="{StaticResource GoldPrimary}"/>
                        <TextBlock Text="灵感记录" 
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="36 条" 
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- 最近笔记 -->
            <TextBlock Text="最近笔记" 
                       Style="{StaticResource SubtitleStyle}"
                       Margin="0,0,0,15"/>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                               Text="C# 异步编程最佳实践" 
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               FontFamily="Microsoft YaHei"/>
                    
                    <TextBlock Grid.Row="1" 
                               Text="async 和 await 的正确使用方式，避免常见的异步编程陷阱..."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                    
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="&#xE8A9;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="12"
                                   Foreground="{StaticResource GoldMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="学习笔记" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="5,0,15,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE823;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="12"
                                   Foreground="{StaticResource GoldMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="2024-01-14" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Border Grid.Column="1" 
                            Grid.RowSpan="3"
                            Background="{StaticResource BackgroundHover}"
                            CornerRadius="4"
                            Padding="8,4"
                            VerticalAlignment="Top">
                        <TextBlock Text="C#" 
                                   Foreground="{StaticResource GoldPrimary}"
                                   FontSize="11"/>
                    </Border>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                               Text="Docker 常用命令速查" 
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               FontFamily="Microsoft YaHei"/>
                    
                    <TextBlock Grid.Row="1" 
                               Text="容器、镜像、网络的常用操作命令整理..."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                    
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="&#xE70B;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="12"
                                   Foreground="{StaticResource GoldMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="代码片段" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="5,0,15,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE823;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="12"
                                   Foreground="{StaticResource GoldMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="2024-01-12" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Border Grid.Column="1" 
                            Grid.RowSpan="3"
                            Background="{StaticResource BackgroundHover}"
                            CornerRadius="4"
                            Padding="8,4"
                            VerticalAlignment="Top">
                        <TextBlock Text="Docker" 
                                   Foreground="{StaticResource GoldPrimary}"
                                   FontSize="11"/>
                    </Border>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                               Text="设计模式：单例模式的多种实现" 
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               FontFamily="Microsoft YaHei"/>
                    
                    <TextBlock Grid.Row="1" 
                               Text="饿汉式、懒汉式、双重检查锁定的优缺点分析..."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                    
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="&#xE8A9;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="12"
                                   Foreground="{StaticResource GoldMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="学习笔记" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="5,0,15,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE823;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="12"
                                   Foreground="{StaticResource GoldMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="2024-01-08" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Border Grid.Column="1" 
                            Grid.RowSpan="3"
                            Background="{StaticResource BackgroundHover}"
                            CornerRadius="4"
                            Padding="8,4"
                            VerticalAlignment="Top">
                        <TextBlock Text="设计模式" 
                                   Foreground="{StaticResource GoldPrimary}"
                                   FontSize="11"/>
                    </Border>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                               Text="Git 分支管理策略" 
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               FontFamily="Microsoft YaHei"/>
                    
                    <TextBlock Grid.Row="1" 
                               Text="Git Flow 和 GitHub Flow 的工作流程对比..."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                    
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="&#xE8A9;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="12"
                                   Foreground="{StaticResource GoldMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="学习笔记" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="5,0,15,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE823;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="12"
                                   Foreground="{StaticResource GoldMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="2024-01-05" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Border Grid.Column="1" 
                            Grid.RowSpan="3"
                            Background="{StaticResource BackgroundHover}"
                            CornerRadius="4"
                            Padding="8,4"
                            VerticalAlignment="Top">
                        <TextBlock Text="Git" 
                                   Foreground="{StaticResource GoldPrimary}"
                                   FontSize="11"/>
                    </Border>
                </Grid>
            </Border>
            
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                               Text="SQL 性能优化技巧" 
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               FontFamily="Microsoft YaHei"/>
                    
                    <TextBlock Grid.Row="1" 
                               Text="索引优化、查询优化的实践经验总结..."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                    
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="&#xE70B;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="12"
                                   Foreground="{StaticResource GoldMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="代码片段" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="5,0,15,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE823;" 
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="12"
                                   Foreground="{StaticResource GoldMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="2024-01-02" 
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Border Grid.Column="1" 
                            Grid.RowSpan="3"
                            Background="{StaticResource BackgroundHover}"
                            CornerRadius="4"
                            Padding="8,4"
                            VerticalAlignment="Top">
                        <TextBlock Text="SQL" 
                                   Foreground="{StaticResource GoldPrimary}"
                                   FontSize="11"/>
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
